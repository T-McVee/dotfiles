# SonarQube Cloud project configuration
# Generated by the sonar-integrate skill
#
# Substitute <repo-name> and <Human Readable Name> with values derived in Step 4.
# For monorepos, place one of these files in each JS subproject root.

sonar.projectKey=Mojo-Soup_<repo-name>
sonar.projectName=<Human Readable Name>
sonar.organization=mojo-soup

# Source layout — adjust to match the project
sonar.sources=src
sonar.tests=src
sonar.test.inclusions=**/*.test.ts,**/*.test.tsx,**/*.test.js,**/*.test.jsx,**/*.spec.ts,**/*.spec.tsx,**/*.spec.js,**/*.spec.jsx

# Exclusions — extend per framework (e.g. add .next/ for Next.js)
sonar.exclusions=**/node_modules/**,**/dist/**,**/build/**,**/coverage/**,**/*.d.ts

# Coverage — produced by Jest / Vitest with lcov reporter
sonar.javascript.lcov.reportPaths=coverage/lcov.info
sonar.typescript.lcov.reportPaths=coverage/lcov.info

# Source encoding
sonar.sourceEncoding=UTF-8
