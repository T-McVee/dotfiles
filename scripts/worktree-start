#!/bin/bash

# Create a git worktree and open it in a new tmux window with the standard dev layout
# Usage: ./worktree-start <branch-name>
#
# - Creates a worktree as a sibling dir to the repo root
# - Branch names with / are converted to - for the dir name
# - Adds a new tmux window to the current session

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/lib/tmux-layout.sh"

if [ -z "$1" ]; then
  echo "Usage: $0 <branch-name>"
  exit 1
fi

BRANCH_NAME="$1"
DIR_NAME="wt-${BRANCH_NAME//\//-}"
WINDOW_NAME="[wt]-${BRANCH_NAME//\//-}"

# Must be inside a tmux session
if [ -z "$TMUX" ]; then
  echo "Error: must be run inside a tmux session"
  exit 1
fi

# Must be inside a git repo
if ! git rev-parse --git-dir > /dev/null 2>&1; then
  echo "Error: must be run inside a git repository"
  exit 1
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"
WORKTREE_DIR="$(dirname "$REPO_ROOT")/$DIR_NAME"

# Check if branch already exists
if git show-ref --verify --quiet "refs/heads/$BRANCH_NAME"; then
  echo "Error: branch '$BRANCH_NAME' already exists"
  exit 1
fi

# Check if worktree dir already exists
if [ -d "$WORKTREE_DIR" ]; then
  echo "Error: directory '$WORKTREE_DIR' already exists"
  exit 1
fi

# Check if tmux window name already exists in current session
SESSION_NAME="$(tmux display-message -p '#S')"
if tmux list-windows -t "$SESSION_NAME" -F '#W' | grep -qx "$WINDOW_NAME"; then
  echo "Error: tmux window '$WINDOW_NAME' already exists in session '$SESSION_NAME'"
  exit 1
fi

# Create the worktree with a new branch
git worktree add -b "$BRANCH_NAME" "$WORKTREE_DIR"

# Create a new tmux window in the current session
tmux new-window -t "$SESSION_NAME" -n "$WINDOW_NAME" -c "$WORKTREE_DIR"

# Apply the standard dev layout
setup_dev_layout "$SESSION_NAME:$WINDOW_NAME" "$WORKTREE_DIR"
